# =============================================================================
# tryit — environment configuration
#
# Copy to .env (or export in your shell) before `make server-dev`.
#
# Legend:
#   [REQUIRED]      — server fails to boot without it.
#   [REQUIRED-IF X] — required only when condition X is met.
#   [OPTIONAL]      — has a default; shown value is that default.
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Loopback bind port. [OPTIONAL]
TRYIT_PORT=8765

# Log level: debug | info | warn | error. [OPTIONAL]
TRYIT_LOG_LEVEL=info


# -----------------------------------------------------------------------------
# AI provider (parse cascade)
#
# Pick ONE provider. The matching API key for that provider is REQUIRED — the
# server exits at boot if it can't construct the chosen provider.
# Ollama is the no-key option (uses OLLAMA_HOST instead).
# -----------------------------------------------------------------------------

# Active provider: anthropic | openai | gemini | ollama. [OPTIONAL]
AI_PROVIDER=anthropic

# Anthropic Claude API key. [REQUIRED-IF AI_PROVIDER=anthropic]
ANTHROPIC_API_KEY=

# OpenAI API key. [REQUIRED-IF AI_PROVIDER=openai]
OPENAI_API_KEY=

# Google Gemini API key. [REQUIRED-IF AI_PROVIDER=gemini]
GEMINI_API_KEY=

# Local Ollama host. Used only when AI_PROVIDER=ollama; connection is
# verified at parse time, not boot. [OPTIONAL]
OLLAMA_HOST=http://localhost:11434

# Local Ollama model. Used only when AI_PROVIDER=ollama. [OPTIONAL]
OLLAMA_MODEL=llama3


# -----------------------------------------------------------------------------
# Parse cache (in-memory LRU + disk persistence at ~/.tryit/cache/)
#
# Cache cap (200) is fixed; TTL and on/off switch live here. Disk-backing is
# automatic when $HOME resolves, giving cross-restart persistence.
# -----------------------------------------------------------------------------

# Master cache on/off switch. [OPTIONAL]
TRYIT_CACHE_ENABLED=true

# Entry TTL. Go duration string (e.g. 1h, 30m, 24h). [OPTIONAL]
TRYIT_CACHE_TTL=24h


# -----------------------------------------------------------------------------
# Outbound HTTP (execute)
# -----------------------------------------------------------------------------

# Per-request total timeout. [OPTIONAL]
TRYIT_EXEC_TIMEOUT=30s

# Response body cap in bytes (truncated above this). [OPTIONAL]
TRYIT_EXEC_MAX_RESPONSE_BYTES=10485760

# Skip TLS verification on outbound calls — for self-signed internal hosts
# only. NEVER set true in production. [OPTIONAL]
TRYIT_EXEC_INSECURE_TLS=false


# -----------------------------------------------------------------------------
# Secrets backend
#
# Three providers are available, swappable at boot:
#   env       — read-only, reads TRYIT_SECRET_<NAME> from the process env
#   keychain  — read/write via the OS keyring (macOS Keychain /
#               Windows Credential Manager / Secret Service)
#   file      — read/write to a NaCl-secretbox-encrypted JSON file; the
#               symmetric key is scrypt-derived from TRYIT_SECRETS_PASSPHRASE
# -----------------------------------------------------------------------------

# Provider selector: env | keychain | file. [OPTIONAL]
TRYIT_SECRETS_BACKEND=env

# Encrypted-file path. [REQUIRED-IF TRYIT_SECRETS_BACKEND=file]
TRYIT_SECRETS_FILE=

# Passphrase for the encrypted file. [REQUIRED-IF TRYIT_SECRETS_BACKEND=file]
TRYIT_SECRETS_PASSPHRASE=


# -----------------------------------------------------------------------------
# Per-secret env vars (env backend)
#
# When TRYIT_SECRETS_BACKEND=env, /execute resolves {{secret:NAME}}
# placeholders against these. Names are UPPER_SNAKE_CASE and chosen by the
# panel / AI parse.
#
#   bearer / apiKey: TRYIT_SECRET_<NAME>=<value>
#   basic:           TRYIT_SECRET_<NAME>_USER=<user>
#                    TRYIT_SECRET_<NAME>_PASS=<pass>
#
# Examples (uncomment + fill in to enable):
# -----------------------------------------------------------------------------

# TRYIT_SECRET_STRIPE_API_KEY=sk_test_…
# TRYIT_SECRET_OPENAI_API_KEY=sk-…
# TRYIT_SECRET_TWILIO_SID_USER=AC…
# TRYIT_SECRET_TWILIO_SID_PASS=…


# -----------------------------------------------------------------------------
# Pairing
# -----------------------------------------------------------------------------

# Pairing token file (auto-generated on first start). [OPTIONAL]
TRYIT_PAIR_FILE=


# -----------------------------------------------------------------------------
# Consent (first-use gate per (secret, host))
# -----------------------------------------------------------------------------

# Consent records file (auto-created on first grant). [OPTIONAL]
TRYIT_CONSENT_FILE=


# -----------------------------------------------------------------------------
# Profiles (learned site profiles — opt-in via POST /profiles)
#
# Builtin profiles ship inside the binary (api/profiles.json). Learned
# profiles get persisted here; learned overrides builtin per host.
# -----------------------------------------------------------------------------

# Learned-profile file (auto-created on first POST /profiles). [OPTIONAL]
TRYIT_PROFILES_FILE=
