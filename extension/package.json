{
  "name": "tryit-extension",
  "version": "0.1.0",
  "description": "Browser extension that makes any API docs page executable inline.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.5.0",
    "@types/chrome": "^0.1.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
